original
/target
.claude/
.env
.scannerwork/

# SwiftPM build artifacts for the in-tree SdrCoreKit package.
# Regenerated by `swift build` / `swift test` / `make swift-test`;
# never committed.
apps/macos/Packages/SdrCoreKit/.build/
apps/macos/Packages/SdrCoreKit/Package.resolved

# Xcode-generated per-user state inside the SDRMac.xcodeproj
# bundle. Contains breakpoints, UI layout, the developer's
# Apple team ID, and other machine-local preferences — never
# committed. The pbxproj itself IS committed (it's the shared
# project definition).
apps/macos/SDRMac.xcodeproj/xcuserdata/
apps/macos/SDRMac.xcodeproj/project.xcworkspace/xcuserdata/

# Xcode build outputs for the SDRMac app. Produced by
# `make mac-app` or `xcodebuild`; regenerated from source.
apps/macos/build/

# LLVM code-coverage intermediates dropped in the cwd by
# xcodebuild test runs and by clang/swift instrumentation.
*.profraw
